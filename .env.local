# Server settings
STAGE=development
HOST=localhost
PORT=8080
READ_TIMEOUT=10
WRITE_TIMEOUT=5
ALLOW_ORIGINS=*
DEBUG=true
IS_ENABLE_API_DOCS=true
API_DOCS_PATH=docs

# DB settings
DB_LOG=true
DB_TYPE=mysql
DB_DSN=goone:goone123@tcp(localhost:3306)/goone?charset=utf8mb4&parseTime=True&loc=Local

# JWT settings
JWT_SECRET=jwtsecret
JWT_DURATION=31536001 # 1 year in seconds
JWT_ALGORITHM=HS256

# OpenAI settings
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=60
OPENAI_MAX_RETRIES=2
OPENAI_DEFAULT_MODEL=gpt-4
